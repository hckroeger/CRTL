# Normalize line endings: LF in the repo, auto-converted on checkout.
* text=auto eol=lf

# Binary assets - never touch these.
*.png binary
*.jpg binary
*.ico binary

# Generated / vendored - keep out of diffs and language stats.
# (The build artifact dist/CRTL.html is git-ignored, so it needs no rule.)
package-lock.json -diff linguist-generated
src/icons.bundled.js -diff linguist-generated
